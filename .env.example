# Copy to `.env.local` and fill in real values (never commit `.env.local`).

# --- Optional: Basic Auth (defaults: user test / password test1 if unset) ---
# BASIC_AUTH_USER=test
# BASIC_AUTH_PASSWORD=test1

# --- SMTP (Hostico) — required for sending mail from the contact form ---
SMTP_HOST=glc23.hostico.ro
SMTP_PORT=465
# Use "false" only if your host uses STARTTLS on a non-465 port
SMTP_SECURE=true
SMTP_USER=no-reply@gmdfences.com
SMTP_PASSWORD=
# Optional: display name; default is "GMD Fences <SMTP_USER>"
# SMTP_FROM=GMD Fences <no-reply@gmdfences.com>

# Admin inbox — receives full inquiry (Reply-To = visitor)
CONTACT_ADMIN_EMAIL=test@gardurimd.ro

# Optional: shown as Reply-To on the *visitor* confirmation (so “Reply” goes to a real inbox)
# Defaults to CONTACT_ADMIN_EMAIL if unset
# CONTACT_REPLY_TO=test@gardurimd.ro

# Optional: legacy Resend path if SMTP is not set
# RESEND_API_KEY=
# CONTACT_FROM_EMAIL=
# CONTACT_TO_EMAIL=
